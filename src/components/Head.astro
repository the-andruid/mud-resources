---
// Extends Starlight's default Head with a per-page OG image generated by
// astro-og-canvas at /open-graph/[entry.id].png.
import Default from '@astrojs/starlight/components/Head.astro';

const { entry } = Astro.locals.starlightRoute;
const ogImagePath = `/open-graph/${entry.id.replace(/\.(md|mdx)$/, '')}.png`;
const ogImageUrl = new URL(ogImagePath, Astro.site).href;
---

<Default><slot /></Default>
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:image" content={ogImageUrl} />
